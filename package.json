{
  "name": "@clouder0/betterchat",
  "version": "0.1.14",
  "packageManager": "bun@1.3.6",
  "private": false,
  "scripts": {
    "dev:web": "bun --filter @betterchat/web dev",
    "build:web": "bun --filter @betterchat/web build",
    "test:web": "bun --filter @betterchat/web test",
    "test:unit": "bun run test:web && bun --filter @betterchat/backend test && bun --filter @betterchat/test-utils test",
    "test:e2e": "bun --cwd tests/e2e test",
    "test:e2e:api:smoke": "bash scripts/e2e-api-smoke-test.sh",
    "verify:ci": "bun run typecheck && bun run test:unit && bun run test:e2e && bun run build:dist",
    "verify:integration": "bash scripts/backend-integration-test.sh && bun run test:e2e:api:smoke",
    "typecheck:web": "bun --filter @betterchat/web typecheck",
    "typecheck:contracts": "bun --filter @betterchat/contracts typecheck",
    "typecheck:backend": "bun --filter @betterchat/backend typecheck",
    "typecheck:test-utils": "bun --filter @betterchat/test-utils typecheck",
    "typecheck:e2e": "bun run --cwd tests/e2e typecheck",
    "typecheck": "bun run typecheck:web && bun run typecheck:contracts && bun run typecheck:backend && bun run typecheck:test-utils && bun run typecheck:e2e",
    "build:dist": "bun run scripts/build-dist.ts",
    "build": "bun run build:dist"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "happy-dom": "^20.8.9"
  }
}
