{
  "name": "betterchat",
  "version": "0.1.0",
  "packageManager": "bun@1.3.6",
  "private": true,
  "scripts": {
    "dev:web": "bun --filter @betterchat/web dev",
    "build:web": "bun --filter @betterchat/web build",
    "test:web": "bun --filter @betterchat/web test",
    "test:e2e": "bun --cwd tests/e2e test",
    "typecheck:web": "bun --filter @betterchat/web typecheck",
    "typecheck:contracts": "bun --filter @betterchat/contracts typecheck",
    "typecheck:backend": "bun --filter @betterchat/backend typecheck",
    "typecheck:test-utils": "bun --filter @betterchat/test-utils typecheck",
    "typecheck": "bun run typecheck:web && bun run typecheck:contracts && bun run typecheck:backend && bun run typecheck:test-utils",
    "build:dist": "bun run scripts/build-dist.ts",
    "build": "bun run build:dist"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "happy-dom": "^20.8.9"
  }
}
